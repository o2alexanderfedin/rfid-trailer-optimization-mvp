{
  "model_profile": "quality",
  "commit_docs": true,
  "parallelization": true,
  "search_gitignored": false,
  "brave_search": false,
  "firecrawl": false,
  "exa_search": false,
  "git": {
    "branching_strategy": "phase",
    "phase_branch_template": "feature/phase-{phase}-{slug}",
    "milestone_branch_template": "feature/{milestone}-{slug}",
    "quick_branch_template": "feature/{phase}-{name}",
    "use_git_flow": true
  },
  "workflow": {
    "research": true,
    "plan_check": true,
    "verifier": true,
    "nyquist_validation": true,
    "auto_advance": false,
    "node_repair": true,
    "node_repair_budget": 2,
    "ui_phase": true,
    "ui_safety_gate": true,
    "text_mode": false,
    "research_before_questions": true,
    "discuss_mode": "discuss",
    "skip_discuss": false,
    "code_review": true,
    "code_review_depth": "standard",
    "ai_integration_phase": true,
    "discuss_strategy": "brainstorm",
    "discuss_brainstorm_skill": "superpowers:brainstorming",
    "use_worktrees": false,
    "subagent_timeout": 1800
  },
  "hooks": {
    "context_warnings": true
  },
  "project_code": null,
  "phase_naming": "sequential",
  "agent_skills": {},
  "features": {},
  "granularity": "standard",
  "resolve_model_ids": "omit",
  "mode": "yolo",
  "context_window": 1000000
}
