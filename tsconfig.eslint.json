{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@mm/domain": ["packages/domain/src/index.ts"],
      "@mm/aggregation": ["packages/aggregation/src/index.ts"],
      "@mm/load-planner": ["packages/load-planner/src/index.ts"],
      "@mm/sensor-fusion": ["packages/sensor-fusion/src/index.ts"],
      "@mm/optimizer": ["packages/optimizer/src/index.ts"],
      "@mm/projections": ["packages/projections/src/index.ts"],
      "@mm/event-store": ["packages/event-store/src/index.ts"],
      "@mm/simulation": ["packages/simulation/src/index.ts"],
      "@mm/api": ["packages/api/src/index.ts"]
    }
  },
  "include": [
    "packages/*/src/**/*.ts",
    "packages/*/src/**/*.tsx",
    "packages/*/test/**/*.ts",
    "packages/*/test/**/*.tsx",
    "eslint.config.ts",
    "vitest.config.ts",
    "vitest.coverage.config.ts",
    "packages/web/vite.config.ts",
    "packages/web/playwright.config.ts"
  ],
  "exclude": ["**/dist/**", "**/node_modules/**"]
}
