{
  "name": "@mm/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -b",
    "lint": "eslint src test",
    "test": "vitest run",
    "test:all": "vitest run --root ../.. packages/api/",
    "dev": "tsx watch src/server.ts",
    "demo": "tsx src/main.ts"
  },
  "dependencies": {
    "@alexanderfedin/async-queue": "workspace:*",
    "@mm/aggregation": "workspace:*",
    "@mm/domain": "workspace:*",
    "@mm/event-store": "workspace:*",
    "@mm/load-planner": "workspace:*",
    "@mm/optimizer": "workspace:*",
    "@mm/projections": "workspace:*",
    "@mm/simulation": "workspace:*",
    "@fastify/websocket": "11.2.0",
    "fastify": "5.8.5",
    "kysely": "0.29.2",
    "ws": "8.21.0"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "12.0.3",
    "@types/pg": "8.20.0",
    "@types/ws": "8.18.1",
    "pg": "8.22.0"
  }
