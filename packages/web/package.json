{
  "name": "@mm/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "vite",
    "preview": "vite preview --port 4173",
    "preview:real": "vite preview --config vite.preview-real.config.ts --port 4273",
    "lint": "eslint src test",
