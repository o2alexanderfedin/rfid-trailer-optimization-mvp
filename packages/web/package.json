{
  "name": "@mm/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -b && vite build",
    "dev": "vite",
    "preview": "vite preview --port 4173",
    "preview:real": "vite preview --config vite.preview-real.config.ts --port 4273",
    "lint": "eslint src test",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:real": "MM_E2E_REAL=1 playwright test --project=chromium-real"
  },
  "dependencies": {
    "@mm/api": "workspace:*",
    "ol": "10.9.0",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@mm/event-store": "workspace:*",
    "@mm/projections": "workspace:*",
    "@playwright/test": "1.61.0",
    "@testcontainers/postgresql": "12.0.3",
    "@types/pg": "8.20.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.2.0",
    "kysely": "0.29.2",
    "pg": "8.22.0",
    "vite": "7.3.5"
  }
}
